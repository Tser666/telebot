# backend/.env.example
# 供后端单独部署时使用；与仓库根目录 .env.example 保持同语义。

# 主密钥（必须为 Fernet.generate_key() 生成值）
# 公网部署必填
MASTER_KEY=changeme-replace-with-fernet-key

# JWT 签名密钥（建议 secrets.token_urlsafe(64)）
# 公网部署必填
JWT_SECRET=changeme-please-use-a-long-random-string

# Cookie 安全标记（公网 HTTPS 必须 true）
# 公网部署必填
COOKIE_SECURE=true

# 仅在可信反向代理后启用（Caddy/nginx/traefik）
# 公网部署必填
TRUST_FORWARDED_FOR=true

# 生产数据库口令（必须强随机，不可使用 telebot/changeme）
# 公网部署必填
POSTGRES_PASSWORD=changeme-strong-random-password

# CORS 白名单（只填真实前端域名，多个用逗号分隔）
# 公网部署必填
CORS_ORIGINS=https://telebot.example.com

# 其余常用项（按需调整）
JWT_EXPIRE_SECONDS=43200
POSTGRES_USER=telebot
POSTGRES_DB=telebot
DATABASE_URL=postgresql+asyncpg://telebot:changeme-strong-random-password@localhost:5432/telebot
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT=30
DB_POOL_SIZE_WORKER=1
DB_MAX_OVERFLOW_WORKER=0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=12
REDIS_MAX_CONNECTIONS_WORKER=4
WORKER_RECONCILE_SECONDS=180
LOG_INCOMING_MESSAGES_DEFAULT=false
WEB_HOST=127.0.0.1
WEB_PORT=8000
AUTO_MIGRATE_ON_STARTUP=false
COMMAND_PREFIX=,
SESSION_DIR=./sessions
TG_DEFAULT_PROXY=
LOG_LEVEL=INFO
KILL_SWITCH=false
GLOBAL_API_QPS=0
