# 前端镜像：多阶段构建
#   - builder：node22 alpine，corepack 启用 pnpm，执行 pnpm build
#   - runtime：nginx alpine，托管 dist 静态资源 + 反代后端
# 暴露 80 端口；通过 docker-compose 中 ${WEB_PORT_PUBLISH:-80} 对外发布

FROM node:22-alpine AS builder
WORKDIR /app

# 启用 corepack，使用与 lockfile 匹配的 pnpm 版本
# Using npm to avoid pnpm ERR_PNPM_IGNORED_BUILDS

# 仅拷贝清单先装依赖，命中构建缓存
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

# 拷贝其余源码、docs 与根更新日志（Sidebar 会通过 ?raw 读取 CHANGELOG.md）
COPY frontend/ .
COPY docs/ /docs/
COPY CHANGELOG.md /CHANGELOG.md
RUN npx vite build


FROM nginx:1.27-alpine AS runtime

# 静态资源
COPY --from=builder /app/dist /usr/share/nginx/html
# 站点配置：替换默认 default.conf
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

# 健康检查：能拿到首页即可
HEALTHCHECK --interval=10s --timeout=3s CMD wget -qO- http://127.0.0.1/ >/dev/null 2>&1 || exit 1
