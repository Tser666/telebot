# ── Web 后端配置 ──────────────────────────────────────────────
# 主密钥：用于加密 session/api_hash/totp_secret，丢失等于所有 TG 账号需重新登录
# 生成方式： python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=changeme-replace-with-fernet-key

# JWT 签名密钥（HS256）
# 生成方式： python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=changeme-please-use-a-long-random-string

# JWT 过期时间（秒），默认 12 小时
JWT_EXPIRE_SECONDS=43200

# Cookie 安全：HTTPS 生产部署设为 true（auth_token / pending_totp 都会带 Secure）
# 本地 HTTP 调试保持 false，否则浏览器不会保存 cookie
COOKIE_SECURE=false

# 登录限速：/api/auth/login 与 /register 每分钟最多多少次（IP + username 双维度）
# 0 = 关闭。Redis 故障时自动降级到进程内计数器
LOGIN_RATE_LIMIT_PER_MIN=30

# 是否信任 X-Forwarded-For 取客户端 IP
# 仅在部署在可信反代（nginx / traefik 等）后面时才设 true；
# 直接对外或反代不设头时设为 true 会让攻击者通过伪造头绕过 IP 限速
TRUST_FORWARDED_FOR=false

# 启动期自动迁移（alembic upgrade head）
# 生产建议 false：由 docker-compose/CI 在应用启动前执行一次迁移，避免多实例重复迁移
AUTO_MIGRATE_ON_STARTUP=false

# 数据库 DSN（async）
# ⚠ 生产环境务必修改默认 telebot/telebot 账号密码！prod-up 会强制校验：
#   - POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 三项必须显式设置
#   - POSTGRES_PASSWORD 不能等于 'telebot' / 'changeme' 等弱密码
# 本地开发（make up）允许使用默认值，仅 prod-up 强制校验。
POSTGRES_USER=telebot
POSTGRES_PASSWORD=telebot
POSTGRES_DB=telebot
DATABASE_URL=postgresql+asyncpg://telebot:telebot@localhost:5432/telebot

# 小 VPS 友好的连接池默认值。每个 Python 进程都会各自持有连接池，
# 多账号 worker 场景不要把这里开太大。
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30

# Compose 生产部署时传给 Postgres 的保守内存参数
POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=192MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_MAX_CONNECTIONS=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=16
REDIS_MAXMEMORY=64mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=no
REDIS_SAVE=

# 降低 Python/glibc 多进程场景的内存碎片
MALLOC_ARENA_MAX=2

# Web 监听
WEB_HOST=0.0.0.0
WEB_PORT=8000

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 命令前缀（可在 Web 中改，这是初始默认值）
COMMAND_PREFIX=,

# 加密 session 文件落盘目录（仅 Pyrogram 临时文件需要，正式 session 在 DB）
SESSION_DIR=./sessions

# ── Telegram 出口代理（可选）─────────────────────────────────
# 默认留空 = 直连（VPS 在境外、家庭宽带能直通 TG 的场景下推荐）
#
# 仅在你的网络环境直连不到 TG（如中国大陆办公网、酒店 WiFi）时才需要配置。
# 配置后，所有"未在 UI 里指定 Proxy 行"的账号自动走它；
# 在 UI 里给账号选了具体 Proxy 行（系统设置→代理）则优先用 UI 选的。
#
# 格式（任选其一）：
#   socks5://[user:pass@]host:port       最常用
#   socks4://host:port
#   http://host:port                     HTTP CONNECT 代理
#   不带 scheme（如 127.0.0.1:1080）      默认按 socks5 处理
#
# Docker Compose 部署 + 用宿主机代理时：把 host 写成 host.docker.internal
#   TG_DEFAULT_PROXY=socks5://host.docker.internal:1080
TG_DEFAULT_PROXY=

# 日志级别
LOG_LEVEL=INFO

# 全局总闸（紧急停用所有账号主动动作）
KILL_SWITCH=false

# 全局每秒 API 上限（所有账号合计），0 表示不限
GLOBAL_API_QPS=0
